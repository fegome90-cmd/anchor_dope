#!/usr/bin/env bash

# shellcheck disable=SC1091
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    SPK_HOME="$(cd "$(dirname "$SOURCE")" && cd "$(dirname "$(readlink "$SOURCE")")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SPK_HOME/$SOURCE"
done
SPK_HOME="$(cd "$(dirname "$SOURCE")" && pwd)"
source "$SPK_HOME/shared/utils.sh"

function resolve_project_root() {
    local start_dir="$1"

    if [ -n "$SPK_REPO" ]; then
        echo "$SPK_REPO"
        return 0
    fi

    if git -C "$start_dir" rev-parse --show-toplevel 2>/dev/null; then
        return 0
    fi

    local dir="$start_dir"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/_ctx" ]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done

    echo -e "${RED}ERROR: No se encontró directorio del proyecto.${NC}" >&2
    echo -e "${YELLOW}Opciones:${NC}" >&2
    echo -e "  1. Ejecutar dentro de un repo git" >&2
    echo -e "  2. Crear _ctx/ en la raíz del proyecto" >&2
    echo -e "  3. Usar: SPK_REPO=/path spk <comando>${NC}" >&2
    return 1
}

function usage() {
    cat <<EOM

Sprint Pack Kit — CLI

usage: spk [--repo <path>] <comando> [argumentos]

global:
    --repo <path>      Directorio del proyecto (auto-detecta si no se especifica)

comandos:
    new <slug>           Crear un nuevo sprint pack
    doctor [opción]      Verificar integridad de un pack
    lint [dir]           Ejecutar ShellCheck
    test                 Ejecutar tests
    version              Mostrar versión

opciones doctor:
    --active             Auditar plan activo
    <plan-id>            Auditar plan específico
    <path>               Auditar directorio directo

examples:
    spk new sprint-01
    spk doctor --active
    spk --repo /path/to/project new sprint-01
    spk doctor sprint-01

EOM
}

function main() {
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    SPK_REPO=""
    local cmd=""
    local cmd_args=()

    while [ $# -gt 0 ]; do
        case "$1" in
        --repo)
            SPK_REPO="$2"
            shift 2
            ;;
        --repo=*)
            SPK_REPO="${1#--repo=}"
            shift
            ;;
        -h | --help | help)
            usage
            return 0
            ;;
        *)
            if [ -z "$cmd" ]; then
                cmd="$1"
            else
                cmd_args+=("$1")
            fi
            shift
            ;;
        esac
    done

    if [ -z "$cmd" ]; then
        usage
        exit 1
    fi

    case "$cmd" in
    version)
        echo "spk 1.0.0"
        return 0
        ;;
    new | doctor)
        local project_root
        project_root=$(resolve_project_root "$(pwd)") || exit 1

        if [ "$cmd" = "new" ]; then
            if [ -d "$project_root/_ctx" ] && [ ! -d "$project_root/_ctx/plans" ]; then
                echo -e "${YELLOW}⚠️  El proyecto tiene _ctx/ pero no _ctx/plans/.${NC}" >&2
                echo -e "${YELLOW}   Esto puede ser una estructura vieja del kit.${NC}" >&2
                echo -e "${YELLOW}   spk creará _ctx/plans/ sin tocar lo existente.${NC}" >&2
                echo -e "${YELLOW}   Para migrar packs viejos, muévalos manualmente a _ctx/plans/.${NC}" >&2
                echo "" >&2
            fi
            if [ -f "$project_root/_ctx/plans/active_plan.json" ]; then
                local current_plan
                current_plan=$(grep -o '"active_plan"[[:space:]]*:[[:space:]]*"[^"]*"' "$project_root/_ctx/plans/active_plan.json" 2>/dev/null | grep -o '"[^"]*"$' | tr -d '"')
                if [ -n "$current_plan" ] && [ "$current_plan" != "null" ]; then
                    echo -e "${YELLOW}📌 Plan activo actual: $current_plan${NC}" >&2
                    echo -e "${YELLOW}   El nuevo plan reemplazará el puntero activo.${NC}" >&2
                    echo "" >&2
                fi
            fi
        fi

        local script_name
        case "$cmd" in
        new) script_name="new_sprint_pack" ;;
        *) script_name="$cmd" ;;
        esac
        (cd "$project_root" && bash "$SPK_HOME/${script_name}.sh" "${cmd_args[@]}")
        ;;
    lint)
        bash "$SPK_HOME/lint.sh" "${cmd_args[@]}"
        ;;
    test)
        bash "$SPK_HOME/../tests/run_all.sh"
        ;;
    *)
        echo -e "${RED}ERROR: Comando desconocido '$cmd'${NC}" >&2
        usage
        exit 1
        ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
